---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'AI и нейросети — обзоры, сравнения и туториалы | VibeLab';
const description = 'Обзоры AI-инструментов для создания сайтов и приложений: Lovable, Claude, Gemini, ChatGPT. Как нейросети помогают в работе и бизнесе.';

const articles = [
  { title: 'Lovable в 2026: полный обзор AI-конструктора', url: '/ai/lovable-obzor-2026/', desc: 'Что умеет Lovable, сколько стоит, для кого подходит — честный обзор AI-конструктора сайтов.' },
];
---

<BaseLayout title={title} description={description}>
  <h1>AI и нейросети</h1>
  <p class="category-desc">Обзоры AI-инструментов, сравнения нейросетей, как AI помогает в разных профессиях. Всё о том, как использовать искусственный интеллект для создания проектов без программирования.</p>

  <div class="articles-list">
    {articles.map(a => (
      <a href={a.url} class="article-card">
        <h2>{a.title}</h2>
        <p>{a.desc}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .category-desc { color: var(--color-text-muted); margin-bottom: 2rem; font-size: 1.05rem; }
  .articles-list { display: flex; flex-direction: column; gap: 1rem; }
  .article-card {
    border: 1px solid #e8e8e8; border-radius: 10px; padding: 1.2rem 1.5rem;
    text-decoration: none; color: var(--color-text); transition: border-color 0.2s;
  }
  .article-card:hover { border-color: var(--color-primary); text-decoration: none; }
  .article-card h2 { font-size: 1.2rem; margin-bottom: 0.3rem; }
  .article-card p { font-size: 0.9rem; color: var(--color-text-muted); }
</style>
