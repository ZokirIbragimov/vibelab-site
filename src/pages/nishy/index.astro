---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Решения по нишам — готовые проекты для каждой профессии | VibeLab';
const description = 'Как создать сайт, приложение или CRM для вашей профессии без программиста. Готовые решения для бухгалтеров, тренеров, риелторов, салонов красоты и репетиторов.';

const niches = [
  { name: 'Для бухгалтеров', slug: 'buhgalter', desc: 'Калькуляторы, CRM, автоматизация отчётности', icon: '📊' },
  { name: 'Для фитнес-тренеров', slug: 'trener', desc: 'Запись клиентов, расписание, оплата', icon: '💪' },
  { name: 'Для риелторов', slug: 'rieltor', desc: 'CRM для объектов, база клиентов, показы', icon: '🏠' },
  { name: 'Для салонов красоты', slug: 'parikmakher', desc: 'Сайт с онлайн-записью, портфолио, прайс', icon: '💇' },
  { name: 'Для репетиторов', slug: 'repetitor', desc: 'Платформа уроков, расписание, домашние задания', icon: '📚' },
];
---

<BaseLayout title={title} description={description}>
  <h1>Решения по нишам</h1>
  <p class="category-desc">
    Вайб-кодинг позволяет создать цифровое решение для любой профессии за 1–3 вечера. Выберите свою нишу — в каждой есть пошаговые инструкции и реальные кейсы.
  </p>

  <div class="niches-grid">
    {niches.map(niche => (
      <a href={`/nishy/${niche.slug}/`} class="niche-card">
        <span class="niche-icon">{niche.icon}</span>
        <h2>{niche.name}</h2>
        <p>{niche.desc}</p>
      </a>
    ))}
  </div>

  <div class="cta-block">
    <h3>Не нашли свою профессию?</h3>
    <p>Вайб-кодинг работает для любой задачи. Попробуйте бесплатный мини-курс — за 20 минут создадите прототип для своего бизнеса.</p>
    <a href="https://t.me/Vibecodelab_bot" class="btn-cta" target="_blank" rel="noopener">Начать бесплатно</a>
  </div>
</BaseLayout>

<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .category-desc { color: var(--color-text-muted); margin-bottom: 2rem; font-size: 1.05rem; }
  .niches-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin-bottom: 2.5rem; }
  .niche-card {
    border: 1px solid #e8e8e8; border-radius: 12px; padding: 1.5rem;
    text-decoration: none; color: var(--color-text); transition: border-color 0.2s, box-shadow 0.2s;
  }
  .niche-card:hover { border-color: var(--color-primary); box-shadow: 0 2px 12px rgba(17,180,212,0.1); text-decoration: none; }
  .niche-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .niche-card h2 { font-size: 1.15rem; margin-bottom: 0.3rem; }
  .niche-card p { font-size: 0.9rem; color: var(--color-text-muted); }
  .cta-block {
    background: linear-gradient(135deg, #E8F8FB 0%, #e8f4fd 100%);
    border: 2px solid var(--color-primary); border-radius: 14px;
    padding: 1.5rem 2rem; text-align: center;
  }
  .cta-block h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .cta-block p { color: var(--color-text-muted); margin-bottom: 1rem; }
</style>
