---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const title = 'Вайб-кодинг для фитнес-тренеров — приложения, запись, расписание | VibeLab';
const description = 'Создавайте приложения для записи клиентов, управляйте расписанием и обрабатывайте платежи без разработчика. Инструменты для тренеров и фитнес-студий.';
const articles = [
  {
    title: 'Как фитнес-тренеру сделать приложение для записи клиентов',
    url: '/nishy/trener/prilozhenie-dlya-zapisi-klientov/',
    desc: 'С записью, расписанием и оплатой — без разработчика.'
  }
];
---
<BaseLayout title={title} description={description}>
  <h1>Вайб-кодинг для фитнес-тренеров</h1>
  <p class="category-desc">Создавайте приложения для записи клиентов, управляйте расписанием тренировок и автоматизируйте работу студии — всё своими руками.</p>
  <div class="articles-list">
    {articles.map(a => (
      <a href={a.url} class="article-card">
        <h2>{a.title}</h2>
        <p>{a.desc}</p>
      </a>
    ))}
  </div>
</BaseLayout>
<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .category-desc { color: var(--color-text-muted); margin-bottom: 2rem; font-size: 1.05rem; }
  .articles-list { display: flex; flex-direction: column; gap: 1rem; }
  .article-card { border: 1px solid #e8e8e8; border-radius: 10px; padding: 1.2rem 1.5rem; text-decoration: none; color: var(--color-text); transition: border-color 0.2s; }
  .article-card:hover { border-color: var(--color-primary); text-decoration: none; }
  .article-card h2 { font-size: 1.2rem; margin-bottom: 0.3rem; }
  .article-card p { font-size: 0.9rem; color: var(--color-text-muted); }
</style>