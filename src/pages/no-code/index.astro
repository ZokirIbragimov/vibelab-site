---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'No-code и автоматизация — сравнения, туториалы | VibeLab';
const description = 'Сравнения no-code платформ: Tilda, Bubble, Glide vs вайб-кодинг. Как создать сайт или приложение без программиста.';

const articles = [
  { title: 'Вайб-кодинг vs Tilda vs Bubble: что выбрать в 2026', url: '/no-code/vibecoding-vs-tilda/', desc: 'Честное сравнение для предпринимателей — цены, возможности, скорость, ограничения.' },
];
---

<BaseLayout title={title} description={description}>
  <h1>No-code и автоматизация</h1>
  <p class="category-desc">Сравнения конструкторов сайтов и приложений, туториалы по no-code инструментам, вайб-кодинг как альтернатива традиционному no-code.</p>

  <div class="articles-list">
    {articles.map(a => (
      <a href={a.url} class="article-card">
        <h2>{a.title}</h2>
        <p>{a.desc}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .category-desc { color: var(--color-text-muted); margin-bottom: 2rem; font-size: 1.05rem; }
  .articles-list { display: flex; flex-direction: column; gap: 1rem; }
  .article-card { border: 1px solid #e8e8e8; border-radius: 10px; padding: 1.2rem 1.5rem; text-decoration: none; color: var(--color-text); transition: border-color 0.2s; }
  .article-card:hover { border-color: var(--color-primary); text-decoration: none; }
  .article-card h2 { font-size: 1.2rem; margin-bottom: 0.3rem; }
  .article-card p { font-size: 0.9rem; color: var(--color-text-muted); }
</style>
