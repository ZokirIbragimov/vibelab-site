---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'VibeLab — Вайб-кодинг: создавайте приложения без программирования';
const description = 'Научитесь создавать сайты, приложения и боты с помощью AI. Опишите идею словами — нейросеть создаст рабочий проект. Бесплатный мини-курс из 4 уроков в Telegram.';

// Collect all articles from content directory
const allArticles = await Astro.glob('./ai/*.astro');
const noCodeArticles = await Astro.glob('./no-code/*.astro');
const bizArticles = await Astro.glob('./biznes/*.astro');
const profArticles = await Astro.glob('./professii/*.astro');
const nishyArticles = await Astro.glob('./nishy/**/*.astro');

const categories = [
  { name: 'AI и нейросети', slug: 'ai', desc: 'Обзоры AI-инструментов, сравнения, как AI помогает в профессиях', icon: '🤖' },
  { name: 'No-code и автоматизация', slug: 'no-code', desc: 'Сравнения конструкторов, туториалы, вайб-кодинг vs no-code', icon: '⚡' },
  { name: 'Бизнес и стартапы', slug: 'biznes', desc: 'Как сделать MVP, проверить идею, запустить проект за выходные', icon: '🚀' },
  { name: 'Профессии будущего', slug: 'professii', desc: 'IT без опыта, новые профессии, вайб-кодер — кто это?', icon: '💼' },
  { name: 'Решения по нишам', slug: 'nishy', desc: 'Готовые решения для бухгалтеров, тренеров, риелторов и других', icon: '🎯' },
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <h1>Создавайте приложения без программирования</h1>
    <p class="hero-subtitle">
      Вайб-кодинг — вы описываете идею словами, AI создаёт рабочий проект.
      Сайты, приложения, боты, калькуляторы — за часы, не за месяцы.
    </p>
    <a href="https://t.me/Vibecodelab_bot" class="btn-cta btn-cta-large" target="_blank" rel="noopener">
      Бесплатный мини-курс (4 урока) →
    </a>
  </section>

  <!-- Categories -->
  <section class="categories">
    <h2>Темы</h2>
    <div class="categories-grid">
      {categories.map(cat => (
        <a href={`/${cat.slug}/`} class="category-card">
          <span class="category-icon">{cat.icon}</span>
          <h3>{cat.name}</h3>
          <p>{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- What is vibe coding -->
  <section class="what-is">
    <h2>Что такое вайб-кодинг?</h2>
    <p>
      Вайб-кодинг — это метод создания приложений, при котором вы описываете задачу обычным языком, а AI-инструменты (Lovable, Claude, Gemini) автоматически создают рабочий код. Никакого программирования — только ваши идеи и слова.
    </p>
    <p>
      По данным за 2025–2026, вайб-кодинг позволяет создать MVP продукта за 1–3 дня вместо 2–6 месяцев традиционной разработки. Стоимость — 0 рублей, если делать самому через бесплатные AI-инструменты.
    </p>
    <p>
      Бесплатный мини-курс VibeLab (4 урока в Telegram-боте, каждый по 5 минут) проведёт по всем шагам — от идеи до работающего прототипа.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0;
    border-bottom: 1px solid #eee;
    margin-bottom: 2.5rem;
  }
  .hero h1 {
    font-size: 2.2rem;
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto 1.5rem;
  }
  .btn-cta-large {
    padding: 0.9rem 2rem;
    font-size: 1.05rem;
  }

  .categories { margin-bottom: 3rem; }
  .categories h2 { font-size: 1.5rem; margin-bottom: 1.2rem; }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .category-card {
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 1.2rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .category-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 12px rgba(17,180,212,0.1);
    text-decoration: none;
  }
  .category-icon { font-size: 1.8rem; display: block; margin-bottom: 0.5rem; }
  .category-card h3 { font-size: 1.05rem; margin-bottom: 0.3rem; }
  .category-card p { font-size: 0.85rem; color: var(--color-text-muted); }

  .what-is { margin-bottom: 2rem; }
  .what-is h2 { font-size: 1.5rem; margin-bottom: 1rem; }
  .what-is p { margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .hero h1 { font-size: 1.6rem; }
    .categories-grid { grid-template-columns: 1fr; }
  }
</style>
