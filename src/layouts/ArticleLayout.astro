---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  author: string;
  authorTitle: string;
  datePublished: string;
  dateModified: string;
  category: string;
  categorySlug: string;
  tags?: string[];
  ogImage?: string;
  faq?: { question: string; answer: string }[];
  howToSteps?: { name: string; text: string }[];
  deepLinkSlug?: string;
}

const {
  title, description, author, authorTitle,
  datePublished, dateModified, category, categorySlug,
  tags = [], ogImage, faq = [], howToSteps = [],
  deepLinkSlug
} = Astro.props;

const siteUrl = 'https://vibelab.com.ru';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;
const slug = deepLinkSlug || Astro.url.pathname.replace(/^\/|\/$/g, '').replace(/\//g, '_').substring(0, 40);
const botLink = `https://t.me/Vibecodelab_bot?start=seo_${slug}`;

// Article Schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author,
    "jobTitle": authorTitle
  },
  "datePublished": datePublished,
  "dateModified": dateModified,
  "publisher": {
    "@type": "Organization",
    "name": "VibeLab",
    "url": siteUrl
  },
  "mainEntityOfPage": currentUrl,
  "inLanguage": "ru"
};

// FAQ Schema
const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
} : null;

// HowTo Schema
const howToSchema = howToSteps.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": title,
  "description": description,
  "step": howToSteps.map((s, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": s.name,
    "text": s.text
  }))
} : null;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <!-- Schema.org structured data -->
  <Fragment slot="default">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
  </Fragment>

  <article class="article" itemscope itemtype="https://schema.org/Article">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Главная</a> &rarr;
      <a href={`/${categorySlug}/`}>{category}</a> &rarr;
      <span>{title}</span>
    </nav>

    <!-- Article header -->
    <h1 itemprop="headline">{title}</h1>

    <div class="article-meta">
      <span itemprop="author" itemscope itemtype="https://schema.org/Person">
        <span itemprop="name">{author}</span>, {authorTitle}
      </span>
      &bull;
      <time itemprop="datePublished" datetime={datePublished}>
        {new Date(datePublished).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {dateModified !== datePublished && (
        <span> &bull; Обновлено: <time itemprop="dateModified" datetime={dateModified}>
          {new Date(dateModified).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time></span>
      )}
    </div>

    {tags.length > 0 && (
      <div class="article-tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}

    <!-- Article body (from markdown/content) -->
    <div class="article-body" itemprop="articleBody">
      <slot />
    </div>

    <!-- CTA block at the end of article -->
    <div class="article-cta">
      <h3>Хотите попробовать вайб-кодинг бесплатно?</h3>
      <p>Мы сделали бесплатный мини-курс из 4 уроков — за 20 минут создадите свой первый прототип. Опишите идею словами, AI создаст рабочий проект. Никакого программирования.</p>
      <a href={botLink} class="btn-cta" target="_blank" rel="noopener">
        Начать бесплатно в Telegram
      </a>
    </div>

    <!-- FAQ section -->
    {faq.length > 0 && (
      <section class="faq-section">
        <h2>Часто задаваемые вопросы</h2>
        {faq.map(f => (
          <div class="faq-item">
            <h3>{f.question}</h3>
            <p>{f.answer}</p>
          </div>
        ))}
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .article { max-width: var(--max-width); }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--color-link); }

  h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.8rem;
    color: var(--color-text);
  }

  .article-meta {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .tag {
    background: #E8F8FB;
    color: var(--color-primary);
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    font-size: 0.8rem;
  }

  .article-body {
    margin-bottom: 2rem;
  }
  .article-body :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    color: var(--color-text);
  }
  .article-body :global(h3) {
    font-size: 1.2rem;
    margin: 1.5rem 0 0.8rem;
  }
  .article-body :global(p) {
    margin-bottom: 1rem;
  }
  .article-body :global(ul), .article-body :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }
  .article-body :global(th), .article-body :global(td) {
    border: 1px solid #ddd;
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .article-body :global(th) {
    background: #f5f5f5;
    font-weight: 600;
  }
  .article-body :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 0.5rem 1rem;
    margin: 1.5rem 0;
    background: #F0F9FB;
    font-style: italic;
  }

  /* Mid-article CTA */
  .article-body :global(.mid-cta) {
    background: var(--color-cta-bg);
    border: 1px solid var(--color-cta-border);
    border-radius: 10px;
    padding: 1rem 1.2rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .article-body :global(.mid-cta a) {
    font-weight: 600;
  }

  /* End-of-article CTA */
  .article-cta {
    background: linear-gradient(135deg, #E8F8FB 0%, #F0F9FB 100%);
    border: 2px solid var(--color-primary);
    border-radius: 14px;
    padding: 1.5rem 2rem;
    text-align: center;
    margin: 2rem 0;
  }
  .article-cta h3 {
    font-size: 1.3rem;
    margin-bottom: 0.7rem;
  }
  .article-cta p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  /* FAQ */
  .faq-section {
    margin-top: 2.5rem;
    border-top: 2px solid #eee;
    padding-top: 1.5rem;
  }
  .faq-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .faq-item {
    margin-bottom: 1.5rem;
  }
  .faq-item h3 {
    font-size: 1.05rem;
    color: var(--color-primary-dark);
    margin-bottom: 0.3rem;
  }
  .faq-item p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    h1 { font-size: 1.5rem; }
    .article-cta { padding: 1rem 1.2rem; }
  }
</style>
