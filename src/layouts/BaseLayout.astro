---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const { title, description, ogImage, canonicalUrl, noindex = false } = Astro.props;
const siteUrl = 'https://vibelab.com.ru';
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const image = ogImage || `${siteUrl}/og-default.jpg`;
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:site_name" content="VibeLab — Вайб-кодинг без программирования" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Yandex verification (заменить на реальный) -->
  <!-- <meta name="yandex-verification" content="xxxxxx" /> -->
  <!-- Google verification (заменить на реальный) -->
  <!-- <meta name="google-site-verification" content="xxxxxx" /> -->

  <!-- Yandex Metrika (заменить XXXXXXXX на реальный ID) -->
  <!--
  <script type="text/javascript">
    (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
    (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
    ym(XXXXXXXX, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
  </script>
  -->

  <style is:global>
    :root {
      --color-bg: #F9FAFB;
      --color-text: #121821;
      --color-text-muted: #5C6F8A;
      --color-primary: #11B4D4;
      --color-primary-dark: #0E9AB5;
      --color-accent: #EE2B6C;
      --color-cta-bg: #E8F8FB;
      --color-cta-border: #11B4D4;
      --color-sidebar-bg: #F0F9FB;
      --color-link: #11B4D4;
      --max-width: 820px;
      --sidebar-width: 300px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.7;
      font-size: 17px;
    }

    a { color: var(--color-link); text-decoration: none; }
    a:hover { text-decoration: underline; }

    img { max-width: 100%; height: auto; }

    /* Header */
    .site-header {
      background: #fff;
      color: var(--color-text);
      padding: 0.8rem 1.5rem;
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(17, 180, 212, 0.15);
      backdrop-filter: blur(8px);
    }
    .site-header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-logo {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--color-text);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .site-logo-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      background: var(--color-primary);
      border-radius: 50%;
      color: #fff;
      font-size: 0.85rem;
      font-family: monospace;
      font-weight: 700;
    }
    .site-logo span { color: var(--color-primary); }
    .site-nav { display: flex; gap: 1.5rem; }
    .site-nav a { color: var(--color-text-muted); font-size: 0.95rem; }
    .site-nav a:hover { color: var(--color-primary); text-decoration: none; }

    /* Main layout */
    .page-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      gap: 2rem;
      padding: 2rem 1.5rem;
    }
    .main-content { flex: 1; min-width: 0; }
    .sidebar {
      width: var(--sidebar-width);
      flex-shrink: 0;
    }

    /* Sidebar CTA widget */
    .sidebar-cta {
      background: var(--color-sidebar-bg);
      border: 2px solid var(--color-primary);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      position: sticky;
      top: 80px;
    }
    .sidebar-cta h3 {
      font-size: 1.1rem;
      margin-bottom: 0.8rem;
      color: var(--color-text);
    }
    .sidebar-cta p {
      font-size: 0.9rem;
      color: var(--color-text-muted);
      margin-bottom: 1rem;
    }
    .btn-cta {
      display: inline-block;
      background: var(--color-primary);
      color: #fff;
      padding: 0.7rem 1.5rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-cta:hover { background: var(--color-primary-dark); text-decoration: none; }

    /* Footer */
    .site-footer {
      background: #121821;
      color: #9CA3AF;
      padding: 2rem 1.5rem;
      margin-top: 3rem;
      text-align: center;
      font-size: 0.9rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .page-container { flex-direction: column; padding: 1rem; }
      .sidebar { width: 100%; }
      .sidebar-cta { position: static; }
      .site-nav { gap: 0.8rem; }
      .site-nav a { font-size: 0.85rem; }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo"><span class="site-logo-icon">&gt;_</span>VIBE<span>LAB</span></a>
      <nav class="site-nav">
        <a href="/ai/">AI-инструменты</a>
        <a href="/no-code/">No-code</a>
        <a href="/biznes/">Бизнес</a>
        <a href="/professii/">Профессии</a>
        <a href="/nishy/">Ниши</a>
      </nav>
    </div>
  </header>

  <!-- Page content -->
  <div class="page-container">
    <main class="main-content">
      <slot />
    </main>

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-cta">
        <h3>Создай свой проект за 20 минут</h3>
        <p>Бесплатный мини-курс из 4 уроков. Опиши идею словами — AI создаст рабочий прототип.</p>
        <a href="https://t.me/Vibecodelab_bot" class="btn-cta" target="_blank" rel="noopener">
          Начать бесплатно
        </a>
      </div>
    </aside>
  </div>

  <!-- Footer -->
  <footer class="site-footer">
    <p>VibeLab — вайб-кодинг для всех. Создавайте приложения без программирования.</p>
    <p style="margin-top: 0.5rem;">
      <a href="https://t.me/Vibecodelab_bot" style="color: var(--color-accent);">Бесплатный мини-курс в Telegram</a>
    </p>
  </footer>

  <!-- Scroll popup (60% scroll trigger) -->
  <div id="scroll-popup" style="display:none; position:fixed; bottom:20px; right:20px; background:#fff; border:2px solid var(--color-primary); border-radius:12px; padding:1.2rem 1.5rem; max-width:340px; box-shadow:0 8px 30px rgba(0,0,0,0.15); z-index:999;">
    <button onclick="this.parentElement.style.display='none'" style="position:absolute;top:8px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:#999;">&times;</button>
    <p style="font-weight:600;font-size:1rem;margin-bottom:0.5rem;">Хотите попробовать вайб-кодинг бесплатно?</p>
    <p style="font-size:0.9rem;color:#555;margin-bottom:0.8rem;">4 урока, 20 минут — и ваш первый прототип готов</p>
    <a href="https://t.me/Vibecodelab_bot" class="btn-cta" target="_blank" rel="noopener" style="display:block;text-align:center;">Перейти в бот</a>
  </div>

  <!-- AI referrer detection + dynamic deep links -->
  <script>
    // Show popup after 60% scroll
    (function() {
      let shown = false;
      window.addEventListener('scroll', function() {
        if (shown) return;
        const scrollPercent = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
        if (scrollPercent > 0.6) {
          shown = true;
          document.getElementById('scroll-popup').style.display = 'block';
        }
      });
    })();

    // Detect AI referrer and update deep links
    (function() {
      const ref = document.referrer.toLowerCase();
      const aiPlatforms = {
        'chat.openai.com': 'ai-chatgpt',
        'chatgpt.com': 'ai-chatgpt',
        'gemini.google.com': 'ai-gemini',
        'perplexity.ai': 'ai-perplexity',
        'copilot.microsoft.com': 'ai-copilot',
        'ya.ru/ai': 'ai-yaneuro',
        'neuro.ya.ru': 'ai-yaneuro',
        'claude.ai': 'ai-claude'
      };

      let source = 'seo';
      for (const [domain, label] of Object.entries(aiPlatforms)) {
        if (ref.includes(domain)) { source = label; break; }
      }

      // Build slug from URL path
      const slug = window.location.pathname.replace(/^\/|\/$/g, '').replace(/\//g, '_').substring(0, 40);
      const startParam = `${source}_${slug}`.substring(0, 64);

      // Update all bot links
      document.querySelectorAll('a[href*="t.me/Vibecodelab_bot"]').forEach(link => {
        link.href = `https://t.me/Vibecodelab_bot?start=${startParam}`;
      });
    })();
  </script>
</body>
</html>
